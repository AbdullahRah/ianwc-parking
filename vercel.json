{
  "version": 2,
  "crons": [
    { "path": "/api/cron", "schedule": "*/5 * * * *" }
  ],
  "routes": [
    { "src": "/admin",    "dest": "/admin.html" },
    { "src": "/display",  "dest": "/display.html" },
    { "src": "/",         "dest": "/display.html" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)",     "dest": "/$1" }
  ]
}
